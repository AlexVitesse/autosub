# Groq API keys (get yours at https://console.groq.com/keys)
# Separate multiple keys with commas for automatic rotation on rate limits
GROQ_API_KEYS="gsk_your_key_here"

# Models
WHISPER_MODEL=whisper-large-v3-turbo
GROQ_MODEL=llama-3.3-70b-versatile

# Languages
SOURCE_LANGUAGE=en
TARGET_LANGUAGE=es
